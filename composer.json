{
	"name": "flarum-lang/telugu",
	"type": "flarum-extension",
	"description": "Telugu language pack for Flarum.",
	"homepage": "https://github.com/flarum-lang/telugu/",
	"keywords": [
		"locale",
		"flarum",
		"telugu-locale"
	],
	"license": "MIT",
	"support": {
		"issues": "https://github.com/flarum-lang/telugu/issues",
		"source": "https://github.com/flarum-lang/telugu/"
	},
	"require": {
		"flarum/core": "^2.0"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"flarum-extension": {
			"title": "Telugu",
			"category": "language",
			"icon": {
				"image": "icon.svg",
				"backgroundSize": "cover",
				"backgroundPosition": "center"
			}
		},
		"flarum-locale": {
			"code": "te",
			"title": "Telugu"
		},
		"flagrow": {
			"discuss": ""
		},
		"branch-alias": {
			"dev-master": "1.x-dev"
		}
	}
}
